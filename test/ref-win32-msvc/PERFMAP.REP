           sfCon = "con-AtticTruss"
           sfArea = 1209.834839
           sfAzm = 0
           sfModel = "Forward_Difference"
           sfExCnd = "Adiabatic"
        
        PERFORMANCEMAP "PMHtg"
        
            PMGRIDAXIS "HtgDBT" pmGXType = "DBT"  pmGXValues = -5, 5, 17, 47, 60 pmGXRefValue = 47
            PMGRIDAXIS "HtgSpeed" pmGXType = "Speed" pmGXValues = 1, 2, 3 pmGXRefValue = 2
        
            // Capacity ratio = net total capacity / net rated total capacity
            PMLOOKUPDATA LUHtgCapRat pmLUType = "CapRat" pmLUValues =
              0.15, 0.58, 0.59,   // -5F at min, mid, max speed
              0.19, 0.73, 0.75,   // 5F
              0.22, 0.68, 0.83,   // 17F
              0.31, 1.00, 1.18,   // 47F
              0.31, 1.00, 1.18    // 60F
        
            // COP = net total COP
            PMLOOKUPDATA LUHtgCOP pmLUType = "COP" pmLUValues =
              1.73, 1.69, 1.69,   // -5F at min, mid, max speed
              2.00, 1.92, 1.91,   // 5F
              2.82, 2.70, 2.38,   // 17F
              4.52, 3.69, 3.33,   // 47F
              4.52, 3.69, 3.33    // 60F
        
        endPERFORMANCEMAP
        
        
        PERFORMANCEMAP "PMClg"
        
            PMGRIDAXIS "ClgDBT" pmGXType = "DBT" pmGXValues = 60, 82, 95, 115 pmGXRefValue = 95
            PMGRIDAXIS "ClgSpeed" pmGXType = "Speed" pmGXValues = 1, 2, 3 pmGXRefValue = 2
        
            // Capacity ratio = net total capacity / net rated total capacity
            PMLOOKUPDATA LUClgCapRat pmLUType = "CapRat" pmLUValues =
              0.48, 1.13, 1.26,   // 60F at min, mid, max speed
              0.42, 1.05, 1.17,   // 82F
              0.39, 1.00, 1.12,   // 95F
              0.34, 0.92, 1.04    // 115F
        
            // COP = net total COP
            PMLOOKUPDATA LUClgCOP pmLUType = "COP" pmLUValues =
              14.22, 16.44, 15.00,   // 60F at min, mid, max speed
               7.93,  7.59,  6.71,   // 82F
               6.01,  5.58,  4.91,   // 95F
               4.12,  3.82,  3.34    // 115F
        
        endPERFORMANCEMAP
        
        RSYS   "Sys1"
           rsType = ASHPPM
           rsSEER = 14
           rsVfPerTon = 350
           rsFanPwrH = 0.58
           rsFanPwrC = 0.58
           
           AUTOSIZE rsCap47
           AUTOSIZE rsCapAuxH
           // rsCapC default from rsCap47
           rsHSPF = 8.7
        
           rsFChgH = .98
           rsFChgC = .96
              
           rsFxCapH = 1.5
           rsElecMtr = "MtrElec"
           rsLoadMtr = "MtrLoads"
        
           rsPerfMapHtg = "PMHtg"
           rsPerfMapClg = "PMClg"
          
        
