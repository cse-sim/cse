            Reportcol colVal=(@znRes["House"].H.qlIg)/CSEBtuSF colHead="ItgL" colDec=2 colWid=5
            Reportcol colVal=(@znRes["House"].H.qlAir)/CSEBtuSF colHead="AirL" colDec=2 colWid=5         
