PERFORMANCEMAP "PMHtg"

    PMGRIDAXIS "HtgDBT" pmGXType = "DBT"  pmGXValues = -5, 5, 17, 47, 60 pmGXRefValue = 47
    PMGRIDAXIS "HtgSpeed" pmGXType = "Speed" pmGXValues = 1, 2, 3 pmGXRefValue = 2

    // Capacity ratio = net total capacity / net rated total capacity
    PMLOOKUPDATA LUHtgCapRat pmLUType = "CapRat" pmLUValues =
      0.15, 0.58, 0.59,   // -5F at min, mid, max speed
      0.19, 0.73, 0.75,   // 5F
      0.22, 0.68, 0.83,   // 17F
      0.31, 1.00, 1.18,   // 47F
      0.31, 1.00, 1.18    // 60F

    // COP = net total COP
    PMLOOKUPDATA LUHtgCOP pmLUType = "COP" pmLUValues =
      1.73, 1.69, 1.69,   // -5F at min, mid, max speed
      2.00, 1.92, 1.91,   // 5F
      2.82, 2.70, 2.38,   // 17F
      4.52, 3.69, 3.33,   // 47F
      4.52, 3.69, 3.33    // 60F

endPERFORMANCEMAP


PERFORMANCEMAP "PMClg"

    PMGRIDAXIS "ClgDBT" pmGXType = "DBT" pmGXValues = 60, 82, 95, 115 pmGXRefValue = 95
    PMGRIDAXIS "ClgSpeed" pmGXType = "Speed" pmGXValues = 1, 2, 3 pmGXRefValue = 2

    // Capacity ratio = net total capacity / net rated total capacity
    PMLOOKUPDATA LUClgCapRat pmLUType = "CapRat" pmLUValues =
      0.48, 1.13, 1.26,   // 60F at min, mid, max speed
      0.42, 1.05, 1.17,   // 82F
      0.39, 1.00, 1.12,   // 95F
      0.34, 0.92, 1.04    // 115F

    // COP = net total COP
    PMLOOKUPDATA LUClgCOP pmLUType = "COP" pmLUValues =
      14.22, 16.44, 15.00,   // 60F at min, mid, max speed
       7.93,  7.59,  6.71,   // 82F
       6.01,  5.58,  4.91,   // 95F
       4.12,  3.82,  3.34    // 115F

endPERFORMANCEMAP

RSYS   "rsys-HVAC System"  
   rsType = "ASHPPM"               // System type
   AUTOSIZE rsCapC
   AUTOSIZE rsCap47
   rsCapAuxH = 30000
   rsFxCapC = 1.2                       // Cooling sizing factor
   rsFChgC = 0.96                       // Refrigerant charge adjustment factor (for cooling)
   rsSEER = 15.052632                   // Cooling SEER
   rsHSPF = 9
   rsVfPerTon = 350                     // CFM per Ton (default = 350)
   rsFanMotTy = "PSC"                   // Fan motor type
   rsFanPwrH = 0.45                     // Heating fan power.  Heating air flow is estimated based on a 50 ?F temperature rise.
   rsFanPwrC = 0.45                     // Cooling fan power.
   rsParElec = ($tdboHrAv < 50.) * (1.-@RSYSRes["rsys-HVAC System"].prior.H.hrsOn) * max( 36000, @RSYS["rsys-HVAC System"].capNomC ) * 10./12000.    // Parasitic electric use, W
   rsFxCapH = 1.2                       // Heating sizing factor
   rsCdC = 0.08                         // Cooling cyclic degradation coefficient, ratio
   rsOAVType = "None"                   // OAV system type
   rsElecMtr = "MtrElec"                // Electric use meter
   rsPerfMapHtg = "PMHtg"
   rsPerfMapClg = "PMClg"

   DUCTSEG   "SupplyDuct-rsys-HVAC System"  
      dsTy = "SUPPLY"
      dsInArea = 337.5                  // Duct segment inside surface area (at duct wall, duct wall thickness assumed negligible) for round shaped duct., ft2
      dsDiameter = 0.666667             // Duct segment round duct diameter (duct wall thickness assumed negligible), ft
      dsAdjZn = "Attic-atc"
      dsInsulR = 7.627143
      dsLeakF = 0.0351

   DUCTSEG   "ReturnDuct-rsys-HVAC System"  
      dsTy = "RETURN"
      dsInArea = 62.5                   // Duct segment inside surface area (at duct wall, duct wall thickness assumed negligible) for round shaped duct., ft2
      dsDiameter = 1.333333             // Duct segment round duct diameter (duct wall thickness assumed negligible), ft
      dsAdjZn = "Attic-atc"
      dsInsulR = 7.627143
      dsLeakF = 0.0249

PVARRAY   "pvarray 1"  
   pvDCSysSize = 10                     // Rated array output, kW
   pvModuleType = "Standard"
   pvArrayType = "FixedOpenRack"
   pvTilt = 22.619884                   // Array tilt (0=H, 90=V), deg
   pvAzm = 170                          // Array azimuth (0=N, 90=E, ...), deg
   pvInverterEff = 0.96                 // Inverter efficiency at full load, frac
   pvSIF = 2                            // Shading impact factor - ratio of relative power output to fraction shaded: PwrOut = PwrSys*(1-SIF*FracShaded), ratio
   pvSysLosses = 0.1744                 // Total system losses, frac
   pvElecMtr = "MtrElec"                // Electric meter to report results to

BATTERY   "battery 1"  
   btChgEff = 0.95                      // The charging efficiency of storing electricity into the BATTERY system
   btDschgEff = 0.95                    // The discharge efficiency for when the BATTERY system is discharging power
   btMaxCap = 8.5                       // The maximum amount of energy that can be stored in the BATTERY system, kWh
   btMaxChgPwr = 3.57143                // The maximum rate at which the BATTERY can be charged in kilowatts (i.e., energy flowing into the BATTERY), kW
   btMaxDschgPwr = 3.57143              // The maximum rate at which the BATTERY can be discharged in kilowatts (i.e., energy flowing out of the BATTERY), kW
   btMeter = "MtrElec"                  // Electric meter to log charge/discharge to

ALTER ZONE "Unit1-zn";
    znTC = 75;
    znTH = 70;
    znTD = 72;

ALTER PVARRAY "pvarray 1";
    pvDCSysSize = 5;

IMPORTFILE btCR imFileName="importfile_test.dat" imFreq=Hour imTitle="x-ZoneTStat"
ALTER BATTERY "battery 1";
    btMaxCap = 13.5;
    btMaxChgPwr = 5.67;
    btMaxDschgPwr = 5.67;
    // btChgReq = import(btCR, "btChgReq_custom");
    btChgReq = select(
       import(btCR, "btChgReq_custom")!=0, import(btCR, "btChgReq_custom")
       default -@BATTERY[ 1].loadSeen)

#define kw_to_btuh 3412.142

DELETE Report "eb"

REPORT rpType=MTR rpMeter=MtrElec rpFreq=MONTH rpBtuSf=kw_to_btuh

REPORT  rpType = UDT rpFreq = HOUR rpTitle = "Battery/PV Output"
    rpDayBeg = jun 29 rpDayEnd = jul 1
    ReportCol colhead="Hr" colVal=@Top.iHr colWid=2
    ReportCol colhead="Load kW" colVal=@METER["MtrElec"].H.allEU / kw_to_btuh colDec=3 colWid=8
    ReportCol colhead="PV kW" colVal=@METER["MtrElec"].H.pv / kw_to_btuh colDec=3 colWid=8
    ReportCol colhead="Bat kW" colVal=@METER["MtrElec"].H.bt / kw_to_btuh colDec=3 colWid=8
    ReportCol colhead="Grid kW" colVal=@METER["MtrElec"].H.tot / kw_to_btuh colDec=3 colWid=8
    ReportCol colhead="Bat kWh" colGap=3 colVal=@BATTERY["Battery 1"].energy colDec=3 colWid=8
    ReportCol colhead="LS kW" colVal=@BATTERY["Battery 1"].loadseen colDec=3 colWid=8


 RUN
 $EOF
